# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Razorpay
VITE_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Supabase Configuration
VITE_SUPABASE_URL=https://jlurdvoylsocvqoiamde.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbG...
VITE_MISTRAL_API_KEY=your_mistral_api_key_here
VITE_GITHUB_CLIENT_ID=your_github_oauth_app_client_id
VITE_RAZORPAY_KEY_ID=rzp_live_your_key_here
VITE_APP_URL=https://arkvoid.cherazen.com
VITE_APP_NAME=ARKVOID

# Conversion rates (update periodically)
VITE_USD_TO_INR=95.93
